<Configuration>
<MappedFolders>
  <MappedFolder>
    <HostFolder>D:\Sandbox\Game\SRO</HostFolder>
    <SandboxFolder>C:\Users\WDAGUtilityAccount\Documents</SandboxFolder>
  </MappedFolder>
</MappedFolders>
<MemoryInMB>16384</MemoryInMB>
